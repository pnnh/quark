{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 29,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux",
      "installDir": "${sourceDir}/install/linux",
      "toolchainFile": "$env{HOME}/opt/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
        "CMAKE_MAKE_PROGRAM": "ninja",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      },
      "environment": {}
    },
    {
      "name": "macos",
      "displayName": "macOS Config",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/macos",
      "installDir": "${sourceDir}/install/macos",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0",
        "VCPKG_HOST_TRIPLET": "arm64-osx",
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "CMAKE_CXX_COMPILER_LAUNCHER": "/opt/homebrew/bin/ccache",
        "CMAKE_C_COMPILER_LAUNCHER": "/opt/homebrew/bin/ccache",
        "CMAKE_OSX_SYSROOT": "macosx"
      },
      "environment": {}
    },
    {
      "name": "windows",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/windows",
      "installDir": "${sourceDir}/install/windows",
      "toolchainFile": "$env{VCPKG_ROOT}\\scripts\\buildsystems\\vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
        "VCPKG_HOST_TRIPLET": "x64-windows",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "FEATURES": "http,database,yaml",
        "QUARK_BUILD_TESTS": "ON"
      },
      "environment": {}
    }
  ],
  "buildPresets": [
    {
      "name": "linux",
      "configurePreset": "linux"
    },
    {
      "name": "macos",
      "configurePreset": "macos"
    },
    {
      "name": "windows",
      "configurePreset": "windows"
    }
  ]
}
